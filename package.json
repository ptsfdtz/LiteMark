{
  "name": "lite-mark",
  "private": true,
  "version": "0.1.9",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0 <25",
    "pnpm": "11.7.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm typecheck && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "version:check": "node scripts/check-version.mjs",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,css,scss,html}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,css,scss,html}\" --end-of-line auto",
    "lint": "eslint \"src/**/*.{ts,tsx,js,jsx}\" --fix",
    "lint:check": "eslint \"src/**/*.{ts,tsx,js,jsx}\" --max-warnings 0",
    "stylelint": "stylelint \"src/**/*.{css,scss}\" --fix",
    "stylelint:check": "stylelint \"src/**/*.{css,scss}\"",
    "check": "pnpm format:check && pnpm lint:check && pnpm stylelint:check && pnpm typecheck && pnpm test"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "src/**/*.{css,scss}": [
      "prettier --write",
      "stylelint --fix"
    ],
    "src/**/*.{html,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/plugin-dialog": "^2.5.0",
    "@tauri-apps/plugin-store": "^2.4.2",
    "github-slugger": "^2.0.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.25",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "react-joyride": "^3.2.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "remark-emoji": "^5.0.2",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.39.1",
    "@tauri-apps/cli": "^2.9.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.2.7",
    "prettier": "^3.6.2",
    "stylelint": "^16.26.0",
    "stylelint-config-standard-scss": "^16.0.0",
    "stylelint-order": "^7.0.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.2.4",
    "vitest": "^4.1.10"
  }
}
